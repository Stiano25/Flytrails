# Resend (https://resend.com) — required for the contact form to send email.
RESEND_API_KEY=

CONTACT_MAIL_TO=info@flytrailstravels.com

CONTACT_MAIL_FROM=Flytrails Website <onboarding@resend.dev>

# Supabase — Express /api/admin only (never put the service role in Vite).
# Server accepts SUPABASE_URL or the same URL as VITE_SUPABASE_URL from your .env.
SUPABASE_SERVICE_ROLE_KEY=
